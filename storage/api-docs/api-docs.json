{
    "openapi": "3.0.0",
    "info": {
        "title": "MovieShelf API v2",
        "description": "API Dokumentation für MovieShelf - Dein digitales Filmregal",
        "contact": {
            "email": "support@neuhaus.ovh"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "2.1.7"
    },
    "servers": [
        {
            "url": "https://neuhaus.ovh/api",
            "description": "MovieShelf API Server"
        }
    ],
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Benutzer-Login",
                "operationId": "67d6d0fdd54fba132e1b6f55ca254183",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "test@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "mobile_app"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Erfolgreich eingeloggt oder 2FA-Herausforderung",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "properties": {
                                                "token": {
                                                    "type": "string"
                                                },
                                                "user": {
                                                    "type": "object"
                                                },
                                                "version": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        {
                                            "properties": {
                                                "requires_2fa": {
                                                    "type": "boolean"
                                                },
                                                "user_id": {
                                                    "type": "integer"
                                                },
                                                "device_name": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validierungsfehler"
                    }
                }
            }
        },
        "/login/2fa": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "2FA-Verifizierung",
                "operationId": "4c9ee982a5eef4e86b4bdcea31cfd8d3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "mobile_app"
                                    },
                                    "code": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "2FA erfolgreich, Token ausgestellt",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object"
                                        },
                                        "version": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Ungültiger Code"
                    }
                }
            }
        },
        "/user": {
            "put": {
                "tags": [
                    "User"
                ],
                "summary": "Benutzerprofil aktualisieren",
                "operationId": "4bf203be8c8483a553f91d446ebd920e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Neuer Name"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "neu@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "neuespasswort123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "neuespasswort123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profil erfolgreich aktualisiert",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Nicht autorisiert"
                    }
                },
                "security": [
                    {
                        "apiAuth": []
                    }
                ]
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Benutzer-Logout",
                "operationId": "28d48c13fca984400ac8de99f54ee13a",
                "responses": {
                    "200": {
                        "description": "Erfolgreich ausgeloggt",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "apiAuth": []
                    }
                ]
            }
        },
        "/info": {
            "get": {
                "tags": [
                    "System"
                ],
                "summary": "System-Informationen abrufen",
                "operationId": "9a13442d68d8d7bdae9c808d93af7579",
                "responses": {
                    "200": {
                        "description": "System-Informationen (Name, Version)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "app_name": {
                                            "type": "string"
                                        },
                                        "version": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/movies": {
            "get": {
                "tags": [
                    "Movies"
                ],
                "summary": "Filmliste abrufen (paginiert)",
                "operationId": "b20bc5b83ce909fde5b6aac802e2304d",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Anzahl der Filme pro Seite",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Seitenzahl",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Liste der Filme",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "links": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Nicht autorisiert"
                    }
                },
                "security": [
                    {
                        "apiAuth": []
                    }
                ]
            }
        },
        "/movies/{movie}": {
            "get": {
                "tags": [
                    "Movies"
                ],
                "summary": "Film-Details abrufen",
                "operationId": "a4c2b67f1aa700303437b4fdac4f6f37",
                "parameters": [
                    {
                        "name": "movie",
                        "in": "path",
                        "description": "Film ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detaillierte Filminformationen",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "404": {
                        "description": "Film nicht gefunden"
                    }
                },
                "security": [
                    {
                        "apiAuth": []
                    }
                ]
            }
        },
        "/search": {
            "get": {
                "tags": [
                    "Movies"
                ],
                "summary": "Filme suchen",
                "operationId": "84e1cbc6927ea12debc6cb875fe1bfb5",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Suchbegriff (Titel oder Regisseur)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Suchergebnisse",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                },
                "security": [
                    {
                        "apiAuth": []
                    }
                ]
            }
        },
        "/movies/{movie}/watched": {
            "post": {
                "tags": [
                    "Movies"
                ],
                "summary": "Gesehen-Status umschalten",
                "operationId": "8a1df4a843bd36cc9c34ea3ddcd16032",
                "parameters": [
                    {
                        "name": "movie",
                        "in": "path",
                        "description": "Film ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Status erfolgreich geändert",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "is_watched": {
                                            "type": "boolean"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "apiAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "apiAuth": {
                "type": "http",
                "description": "Geben Sie Ihren Bearer-Token im Format 'Bearer {token}' ein.",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "User",
            "description": "User"
        },
        {
            "name": "System",
            "description": "System"
        },
        {
            "name": "Movies",
            "description": "Movies"
        }
    ]
}